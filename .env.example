# Database
DATABASE_URL="postgresql://user:password@localhost:5432/sprich"

# Auth
JWT_SECRET="your-super-secret-jwt-key-change-this"

# App URLs
WEB_URL="http://localhost:3000"
API_URL="http://localhost:4000"

# AI — set EITHER key. The API auto-uses Claude if ANTHROPIC_API_KEY is set,
# otherwise Gemini if GEMINI_API_KEY is set. Force one with AI_PROVIDER.
ANTHROPIC_API_KEY="sk-ant-..."
GEMINI_API_KEY=""            # free tier from aistudio.google.com (AIza...)
GEMINI_MODEL="gemini-2.0-flash"
# AI_PROVIDER="gemini"       # optional: force "gemini" or "anthropic"

# Payments
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PREMIUM_MONTHLY_PRICE_ID="price_..."
STRIPE_PREMIUM_ANNUAL_PRICE_ID="price_..."

# Audio (for TTS — German pronunciation)
ELEVENLABS_API_KEY="..."
# Voice id from your ElevenLabs Voice Library (pick a German/multilingual voice).
# Falls back to a built-in default if unset.
ELEVENLABS_VOICE_ID=""

# Speech-to-text (for speaking evaluation)
DEEPGRAM_API_KEY="..."

# Storage (for audio files)
R2_ACCOUNT_ID="..."
R2_ACCESS_KEY_ID="..."
R2_SECRET_ACCESS_KEY="..."
R2_BUCKET_NAME="sprich-audio"
