# Database
DATABASE_URL="postgresql://user:password@localhost:5432/sprich"

# Auth
JWT_SECRET="your-super-secret-jwt-key-change-this"

# App URLs — WEB_URL may be a comma-separated list (e.g. a custom domain +
# your Vercel project URL). Any https://*.vercel.app origin is always allowed
# too, so Vercel preview deploys work without extra config. localhost:3000 is
# allowed automatically for local dev regardless of this value.
WEB_URL="http://localhost:3000"
API_URL="http://localhost:4000"

# AI — set EITHER key. The API auto-uses Claude if ANTHROPIC_API_KEY is set,
# otherwise Gemini if GEMINI_API_KEY is set. Force one with AI_PROVIDER.
ANTHROPIC_API_KEY="sk-ant-..."
GEMINI_API_KEY=""            # free tier from aistudio.google.com (regional limits)
GEMINI_MODEL="gemini-2.0-flash"
GROQ_API_KEY=""              # free from console.groq.com (gsk_...) — reliable free option
GROQ_MODEL="llama-3.3-70b-versatile"
# AI_PROVIDER="groq"         # optional: force "groq" | "gemini" | "anthropic"

# Payments
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PREMIUM_MONTHLY_PRICE_ID="price_..."
STRIPE_PREMIUM_ANNUAL_PRICE_ID="price_..."

# Audio (for TTS — German pronunciation)
ELEVENLABS_API_KEY="..."
# Voice id — MUST be a PREMADE voice on the free tier (Voice Library voices
# return HTTP 402 via the API). Premade examples: JBFqnCBsd6RMkjVDRZzb (George),
# EXAVITQu4vr4xnSDxMaL (Sarah). Leave empty to use the default (George).
ELEVENLABS_VOICE_ID=""
# Where generated MP3s are cached (repeat plays cost zero credits).
# Defaults to .audio-cache next to the API process.
AUDIO_CACHE_DIR=""

# Speech-to-text (for speaking evaluation)
DEEPGRAM_API_KEY="..."

# Storage (for audio files)
R2_ACCOUNT_ID="..."
R2_ACCESS_KEY_ID="..."
R2_SECRET_ACCESS_KEY="..."
R2_BUCKET_NAME="sprich-audio"
